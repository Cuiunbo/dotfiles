# Font
font-family = JetBrainsMono Nerd Font Mono
font-size = 14

# Theme (auto switch between light/dark)
theme = Catppuccin Mocha

# macOS: left Option as Alt for Zellij keybindings, right Option for special chars
macos-option-as-alt = left

# Window
window-padding-x = 4
window-padding-y = 4
window-decoration = true
macos-titlebar-style = tabs

# Disable Ghostty's own window management (use Zellij instead)
keybind = super+t=unbind
keybind = super+n=unbind

# Cursor
cursor-style = bar
cursor-style-blink = false

# Clipboard
copy-on-select = clipboard
clipboard-paste-protection = false

# Auto-launch Zellij with session picker
command = zsh -l -c 'source ~/.shell/aliases.sh && zj'

# Misc
confirm-close-surface = false
mouse-hide-while-typing = true
shell-integration = zsh
